rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if true;
    }

    match /leads/{leadId} {
      allow read, write: if true;
    }

    match /tasks/{taskId} {
      allow read, write: if true;
    }

    // Fallback for other collections if needed
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
